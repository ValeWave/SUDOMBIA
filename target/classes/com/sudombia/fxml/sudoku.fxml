<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sudombia.controller.SudokuController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #1A1A2E;">

    <!-- Info superior -->
    <top>
        <VBox alignment="CENTER" spacing="4"
              style="-fx-padding: 16 0 8 0;">
            <Label fx:id="ecosystemLabel"
                   style="-fx-font-size: 22px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #E8C84A;"/>
            <Label fx:id="difficultyLabel"
                   style="-fx-font-size: 14px;
                          -fx-text-fill: #A0A0C0;"/>
        </VBox>
    </top>

    <!-- Tablero central -->
    <center>
        <GridPane fx:id="sudokuGrid"
                  alignment="CENTER"
                  hgap="1" vgap="1"
                  style="-fx-padding: 10;"/>
    </center>

    <!-- Panel derecho -->
    <right>
        <VBox alignment="CENTER" spacing="12"
              style="-fx-padding: 20; -fx-min-width: 180;">

            <Label fx:id="hintsLabel"
                   text="Pistas: 3"
                   style="-fx-font-size: 16px;
                          -fx-text-fill: #E8C84A;"/>

            <Label fx:id="messageLabel"
                   text=""
                   wrapText="true"
                   style="-fx-font-size: 13px;
                          -fx-text-fill: #69F0AE;
                          -fx-max-width: 160;"/>

            <Button fx:id="checkButton"
                    text="Comprobar"
                    onAction="#onCheckClicked"
                    prefWidth="150"
                    style="-fx-background-color: #4CAF50;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-background-radius: 8;"/>

            <Button fx:id="hintButton"
                    text="Pista"
                    onAction="#onHintClicked"
                    prefWidth="150"
                    style="-fx-background-color: #FF9800;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-background-radius: 8;"/>

            <Button text="← Volver"
                    onAction="#onBackClicked"
                    prefWidth="150"
                    style="-fx-background-color: #607D8B;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-background-radius: 8;"/>
        </VBox>
    </right>

</BorderPane>