<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sudombia.controller.MapController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #1A1A2E;">

    <!-- Título -->
    <top>
        <Label fx:id="titleLabel"
               text="Elige tu ecosistema"
               BorderPane.alignment="CENTER"
               style="-fx-font-size: 32px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #E8C84A;
                      -fx-padding: 30 0 10 0;"/>
    </top>

    <!-- Lista de ecosistemas -->
    <center>
        <VBox fx:id="ecosystemsContainer"
              alignment="CENTER"
              spacing="14"
              style="-fx-padding: 20;"/>
    </center>

    <!-- Botón volver -->
    <bottom>
    <VBox alignment="CENTER" style="-fx-padding: 0 0 20 0;">
        <Button text="← Volver"
                onAction="#onBackClicked"
                style="-fx-background-color: #607D8B;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-background-radius: 8;
                       -fx-padding: 8 24;"/>
    </VBox>
    </bottom>

</BorderPane>